generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EntryType {
  TEXT
  IMAGE
  VIDEO
  PDF
  FILE
  MIXED
}

enum AssetKind {
  IMAGE
  VIDEO
  PDF
  FILE
}

enum StorageDriver {
  LOCAL
  S3
  WEBDAV
}

model Entry {
  id        String      @id @default(cuid())
  type      EntryType
  senderName String     @default("current-device")
  senderIp   String?
  senderHost String?
  message   String?     @db.Text
  note      String?     @db.Text
  messageFingerprint String? @db.VarChar(64)
  canonicalUrl String?   @db.VarChar(2048)
  linkTitle String?      @db.VarChar(300)
  linkDescription String? @db.Text
  linkSiteName String?   @db.VarChar(120)
  linkImageUrl String?   @db.VarChar(2048)
  linkContentText String? @db.Text
  linkFetchedAt DateTime?
  linkPublishedAt DateTime?
  pinnedAt DateTime?
  isFavorite Boolean    @default(false)
  archivedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  assets    Asset[]
  collections CollectionEntry[]
  tags      EntryTag[]
  shareLink ShareLink?

  @@index([type, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([senderName, createdAt(sort: Desc)])
  @@index([pinnedAt, createdAt(sort: Desc)])
  @@index([isFavorite, createdAt(sort: Desc)])
  @@index([archivedAt, createdAt(sort: Desc)])
  @@index([messageFingerprint, createdAt(sort: Desc)])
  @@index([canonicalUrl, createdAt(sort: Desc)])
  @@index([linkFetchedAt, createdAt(sort: Desc)])
}

model Asset {
  id           String    @id @default(cuid())
  entryId       String
  entry         Entry     @relation(fields: [entryId], references: [id], onDelete: Cascade)
  kind          AssetKind
  storageDriver StorageDriver @default(LOCAL)
  originalName  String
  storedName    String    @unique
  relativePath  String
  mimeType      String
  size          Int
  contentHash   String?   @db.VarChar(64)
  searchText    String?   @db.Text
  searchTextIndexedAt DateTime?
  createdAt     DateTime  @default(now())

  @@index([entryId, createdAt])
  @@index([storageDriver, createdAt])
  @@index([contentHash, createdAt])
}

model SavedView {
  id        String    @id @default(cuid())
  name      String    @db.VarChar(64)
  query     String?   @db.Text
  tagName   String?   @db.VarChar(64)
  entryType EntryType?
  entryView String    @default("ACTIVE") @db.VarChar(24)
  duplicatesOnly Boolean @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([updatedAt])
  @@index([tagName, updatedAt])
}

model Tag {
  id        String     @id @default(cuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  entries   EntryTag[]
}

model EntryTag {
  entryId   String
  tagId     String
  createdAt DateTime @default(now())
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([entryId, tagId])
  @@index([tagId, entryId])
}

model Collection {
  id          String               @id @default(cuid())
  title       String               @db.VarChar(120)
  description String?              @db.Text
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  entries     CollectionEntry[]
  shareLink   CollectionShareLink?

  @@index([updatedAt(sort: Desc)])
}

model CollectionEntry {
  collectionId String
  entryId      String
  position     Int                  @default(0)
  createdAt    DateTime             @default(now())
  collection   Collection           @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  entry        Entry                @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@id([collectionId, entryId])
  @@index([collectionId, position, createdAt])
  @@index([entryId, createdAt])
}

model CollectionShareLink {
  id           String      @id @default(cuid())
  token        String      @unique
  collectionId String      @unique
  collection   Collection  @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())
  revokedAt    DateTime?
}

model ShareLink {
  id        String    @id @default(cuid())
  token     String    @unique
  entryId    String    @unique
  entry      Entry     @relation(fields: [entryId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  revokedAt DateTime?
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
